---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import CategoryBadge from '../components/CategoryBadge.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, forumUrl, tags = [] } = Astro.props;
const displayTag = tags?.find(t => t !== 'featured') || tags?.[0];

// Rough read time estimate
const wordCount = Astro.slots.has('default') ? 800 : 0;
const readTime = Math.max(3, Math.ceil(wordCount / 200));
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="article-hero">
					<div class="hero-inner container">
						{displayTag && <CategoryBadge tag={displayTag} />}
						<h1>{title}</h1>
						<div class="article-meta">
							<FormattedDate date={pubDate} />
							<span class="meta-sep">&middot;</span>
							<span>{readTime} min read</span>
							{forumUrl && (
								<>
									<span class="meta-sep">&middot;</span>
									<a href={forumUrl} class="forum-link">View on Forum</a>
								</>
							)}
						</div>
						{updatedDate && (
							<div class="updated">
								Updated <FormattedDate date={updatedDate} />
							</div>
						)}
					</div>
				</div>

				<div class="article-body container">
					<div class="prose">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: 0;
	}
	.article-hero {
		background: linear-gradient(135deg, #00285E 0%, #0053BC 50%, #0b1a2e 100%);
		padding: 3rem 0;
		margin-bottom: 2rem;
	}
	.article-hero h1 {
		color: white;
		font-size: 2.2rem;
		margin: 0.5rem 0;
		line-height: 1.2;
		max-width: 800px;
	}
	.article-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: rgba(255,255,255,0.65);
		font-size: 0.9rem;
		margin-top: 0.75rem;
		flex-wrap: wrap;
	}
	.meta-sep {
		color: rgba(255,255,255,0.3);
	}
	.forum-link {
		color: rgba(255,255,255,0.8);
		text-decoration: underline;
		text-underline-offset: 2px;
	}
	.forum-link:hover {
		color: white;
	}
	.updated {
		color: rgba(255,255,255,0.5);
		font-size: 0.85rem;
		font-style: italic;
		margin-top: 0.5rem;
	}
	.article-body {
		padding-top: 0;
		padding-bottom: 3rem;
	}
	@media (max-width: 768px) {
		.article-hero {
			padding: 2rem 0;
		}
		.article-hero h1 {
			font-size: 1.6rem;
		}
	}
</style>
