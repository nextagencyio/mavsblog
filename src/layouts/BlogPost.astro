---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import CategoryBadge from '../components/CategoryBadge.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, ogImage, forumUrl, tags = [] } = Astro.props;
const displayTag = tags?.find(t => t !== 'featured') || tags?.[0];
const readTime = Math.max(3, Math.ceil(800 / 200));
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	datePublished: pubDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	author: {
		'@type': 'Organization',
		name: 'MavsBoard Community',
		url: 'https://www.mavsboard.com',
	},
	publisher: {
		'@type': 'Organization',
		name: 'MavsBoard Blog',
		url: 'https://blog.mavsboard.com',
		logo: {
			'@type': 'ImageObject',
			url: 'https://blog.mavsboard.com/images/mavsboard-logo.png',
		},
	},
	mainEntityOfPage: canonicalURL.toString(),
};
---

<html lang="en">
	<head>
		<BaseHead title={`${title} — MavsBoard Blog`} description={description} image={ogImage} />
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="article-hero">
					{heroImage && <Image src={heroImage} alt={title} class="hero-bg-img" width={1400} height={600} />}
					<div class="hero-bg"></div>
					<div class="hero-inner container">
						<div class="hero-meta-top">
							{displayTag && <CategoryBadge tag={displayTag} />}
							<span class="read-time">{readTime} min read</span>
						</div>
						<h1>{title}</h1>
						<p class="hero-description">{description}</p>
						<div class="article-meta">
							<div class="meta-left">
								<img src="/images/mavsboard-logo.png" alt="" class="author-avatar" />
								<div>
									<span class="author-name">MavsBoard Community</span>
									<span class="meta-date"><FormattedDate date={pubDate} /></span>
								</div>
							</div>
							{forumUrl && (
								<a href={forumUrl} class="forum-link" target="_blank" rel="noopener">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
									View on Forum
								</a>
							)}
						</div>
					</div>
				</div>

				<div class="article-body">
					<div class="prose">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main { padding: 0; }

	/* Hero with background image */
	.article-hero {
		position: relative;
		padding: 5rem 0 3.5rem;
		overflow: hidden;
		min-height: 340px;
	}
	.hero-bg-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 0;
	}
	.hero-bg {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			transparent 0%,
			rgba(0, 20, 50, 0.3) 20%,
			rgba(0, 20, 50, 0.7) 50%,
			rgba(0, 15, 40, 0.92) 100%
		);
		z-index: 1;
		backdrop-filter: blur(2px);
		-webkit-backdrop-filter: blur(2px);
	}
	.hero-inner {
		position: relative;
		z-index: 2;
		max-width: 900px;
	}
	.hero-meta-top {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}
	.read-time {
		font-size: 0.8rem;
		color: rgba(255,255,255,0.5);
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}
	.article-hero h1 {
		color: white;
		font-size: 2.5rem;
		margin: 0 0 0.75rem;
		line-height: 1.15;
		font-weight: 800;
	}
	.hero-description {
		color: rgba(255,255,255,0.8);
		font-size: 1.15rem;
		line-height: 1.5;
		margin: 0 0 1.5rem;
		max-width: 700px;
	}
	.article-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
	}
	.meta-left {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.author-avatar {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: rgba(255,255,255,0.15);
		padding: 6px;
	}
	.author-name {
		display: block;
		color: white;
		font-weight: 600;
		font-size: 0.95rem;
	}
	.meta-date {
		display: block;
		color: rgba(255,255,255,0.55);
		font-size: 0.85rem;
	}
	.forum-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		color: rgba(255,255,255,0.8);
		text-decoration: none;
		font-size: 0.9rem;
		padding: 0.5rem 1rem;
		border: 1px solid rgba(255,255,255,0.25);
		border-radius: 6px;
		transition: all 0.2s;
	}
	.forum-link:hover {
		background: rgba(255,255,255,0.1);
		color: white;
		border-color: rgba(255,255,255,0.4);
		text-decoration: none;
	}
	.forum-link svg { flex-shrink: 0; }

	/* Article body — card-style on a subtle background */
	.article-body {
		max-width: 860px;
		margin: -2rem auto 0;
		position: relative;
		z-index: 3;
		background: white;
		border-radius: 12px 12px 0 0;
		padding: 3rem 3.5rem 3rem;
		box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
	}

	@media (max-width: 768px) {
		.article-hero { padding: 3rem 0 2rem; min-height: 260px; }
		.article-hero h1 { font-size: 1.7rem; }
		.hero-description { font-size: 1rem; }
		.article-body { padding: 2rem 1.25rem; margin-top: -1rem; border-radius: 8px 8px 0 0; }
	}
</style>
