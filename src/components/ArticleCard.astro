---
import FormattedDate from './FormattedDate.astro';
import CategoryBadge from './CategoryBadge.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	slug: string;
	tags?: string[];
	variant?: 'horizontal' | 'vertical';
}

const { title, description, pubDate, slug, tags = [], variant = 'horizontal' } = Astro.props;
const displayTag = tags.find(t => t !== 'featured') || tags[0];
---

<a href={`/blog/${slug}/`} class={`article-card ${variant}`}>
	<div class="card-thumb">
		<div class="thumb-placeholder">
			<img src="/images/mavsboard-logo.png" alt="" class="thumb-logo" />
		</div>
	</div>
	<div class="card-body">
		{displayTag && <CategoryBadge tag={displayTag} />}
		<h3 class="card-title">{title}</h3>
		<p class="card-desc">{description}</p>
		<span class="card-date"><FormattedDate date={pubDate} /></span>
	</div>
</a>

<style>
	.article-card {
		display: flex;
		background: var(--card-bg);
		border-radius: var(--radius);
		overflow: hidden;
		text-decoration: none;
		box-shadow: var(--box-shadow);
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.article-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--box-shadow-hover);
		text-decoration: none;
	}

	/* Horizontal (default — for article feeds) */
	.article-card.horizontal {
		flex-direction: row;
	}
	.horizontal .card-thumb {
		flex: 0 0 200px;
		min-height: 160px;
	}
	.horizontal .card-body {
		flex: 1;
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	/* Vertical (for featured grids) */
	.article-card.vertical {
		flex-direction: column;
	}
	.vertical .card-thumb {
		height: 160px;
	}
	.vertical .card-body {
		padding: 1rem;
	}

	.card-thumb {
		position: relative;
		overflow: hidden;
	}
	.thumb-placeholder {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, #0b1a2e, #0053BC);
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.thumb-logo {
		width: 50px;
		height: auto;
		opacity: 0.3;
	}
	.card-title {
		font-size: 1.1rem;
		margin: 0.35rem 0;
		color: var(--text);
		line-height: 1.3;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.card-desc {
		font-size: 0.88rem;
		color: var(--text-muted);
		margin: 0.25rem 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		line-height: 1.5;
	}
	.card-date {
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-top: auto;
	}

	@media (max-width: 768px) {
		.article-card.horizontal {
			flex-direction: column;
		}
		.horizontal .card-thumb {
			flex: none;
			height: 140px;
		}
	}
</style>
