---
import { FORUM_URL } from '../consts';
---

<footer>
	<div class="footer-content">
		<a href="/" class="footer-brand">
			<img src="/images/mavsboard-logo.png" alt="MavsBoard" class="footer-logo" />
			MavsBoard Blog
		</a>
		<div class="footer-links">
			<a href={FORUM_URL}>Forum</a>
			<a href="/blog">Blog</a>
			<a href="/about">About</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em;
		background: #0b1a2e;
		color: #8eafc7;
		text-align: center;
		border-top: 3px solid #0064b1;
	}
	.footer-content {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.footer-brand {
		display: flex;
		align-items: center;
		gap: 8px;
		color: #9fc5e8;
		text-decoration: none;
		font-weight: 600;
	}
	.footer-brand:hover {
		color: #fff;
	}
	.footer-logo {
		height: 24px;
		width: auto;
	}
	.footer-links {
		display: flex;
		gap: 1.5em;
	}
	.footer-links a {
		color: #6a9bc0;
		text-decoration: none;
	}
	.footer-links a:hover {
		color: #fff;
	}
	@media (max-width: 720px) {
		footer {
			padding: 1.5em 1em;
		}
		.footer-content {
			flex-direction: column;
			gap: 0.75em;
		}
		.footer-brand {
			font-size: 0.9rem;
		}
		.footer-links {
			gap: 1em;
			font-size: 0.85rem;
		}
	}
</style>
