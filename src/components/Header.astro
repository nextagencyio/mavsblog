---
import { SITE_TITLE, FORUM_URL } from '../consts';
---

<header>
	<div class="header-top">
		<div class="container header-flex">
			<a href="/" class="brand">
				<img src="/images/mavsboard-logo.png" alt="MavsBoard" class="logo" />
				<span class="site-title">{SITE_TITLE}</span>
			</a>
			<nav class="header-nav">
				<a href="/">Home</a>
				<a href="/blog">Articles</a>
				<a href="/about">About</a>
				<a href={FORUM_URL} class="forum-btn">Forum</a>
			</nav>
		</div>
	</div>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.header-top {
		background: var(--dark);
		border-bottom: 3px solid var(--blue-light);
	}
	.header-flex {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.6rem 1rem;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
	}
	.brand:hover {
		text-decoration: none;
	}
	.logo {
		height: 36px;
		width: auto;
	}
	.site-title {
		font-size: 1.2em;
		font-weight: 700;
		color: #fff;
		letter-spacing: 0.5px;
	}
	.header-nav {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}
	.header-nav a {
		color: #9fc5e8;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		padding: 0.5rem 0.9rem;
		border-radius: 5px;
		transition: background 0.2s, color 0.2s;
	}
	.header-nav a:hover {
		background: rgba(255,255,255,0.1);
		color: #fff;
		text-decoration: none;
	}
	.forum-btn {
		background: var(--blue) !important;
		color: white !important;
		font-weight: 600 !important;
	}
	.forum-btn:hover {
		background: var(--blue-light) !important;
	}
	@media (max-width: 768px) {
		.site-title { display: none; }
		.header-nav a {
			padding: 0.4rem 0.6rem;
			font-size: 0.85rem;
		}
	}
</style>
