---
import { SITE_TITLE, SITE_TAGLINE, FORUM_URL } from '../consts';
---

<header>
	<div class="header-top">
		<div class="container header-flex">
			<a href="/" class="brand">
				<img src="/images/mavsboard-logo.png" alt="MavsBoard" class="logo" />
				<div class="brand-text">
					<span class="site-title">{SITE_TITLE}</span>
					<span class="site-tagline">{SITE_TAGLINE}</span>
				</div>
			</a>
			<nav class="header-nav">
				<a href="/">Home</a>
				<a href="/blog">Articles</a>
				<a href="/about">About</a>
				<a href={FORUM_URL} class="forum-btn" target="_blank" rel="noopener">Forum <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a>
			</nav>
		</div>
	</div>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.header-top {
		background: var(--dark);
		border-bottom: 3px solid var(--blue-light);
	}
	.header-flex {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.6rem 1rem;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
	}
	.brand:hover {
		text-decoration: none;
	}
	.logo {
		height: 36px;
		width: auto;
	}
	.brand-text {
		display: flex;
		flex-direction: column;
		line-height: 1.2;
	}
	.site-title {
		font-size: 1.15em;
		font-weight: 700;
		color: #fff;
		letter-spacing: 0.5px;
	}
	.site-tagline {
		font-size: 0.7em;
		color: rgba(159, 197, 232, 0.7);
		font-weight: 400;
		font-style: italic;
	}
	.header-nav {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}
	.header-nav a {
		color: #9fc5e8;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		padding: 0.5rem 0.9rem;
		border-radius: 5px;
		transition: background 0.2s, color 0.2s;
	}
	.header-nav a:hover {
		background: rgba(255,255,255,0.1);
		color: #fff;
		text-decoration: none;
	}
	.forum-btn {
		background: var(--blue) !important;
		color: white !important;
		font-weight: 600 !important;
	}
	.forum-btn:hover {
		background: var(--blue-light) !important;
	}
	@media (max-width: 768px) {
		.brand-text { display: none; }
		.header-nav a {
			padding: 0.4rem 0.6rem;
			font-size: 0.85rem;
		}
	}
</style>
