---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroPost from '../components/HeroPost.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog'))
	.filter(p => p.data.title !== 'Welcome to MavsBoard Blog')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const heroPost = posts[0];
const featuredPosts = posts.slice(1, 5);
const remainingPosts = posts.slice(5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — Dallas Mavericks News & Fan Discussion`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="container">
				{heroPost && (
					<section class="hero-section">
						<HeroPost
							title={heroPost.data.title}
							description={heroPost.data.description}
							pubDate={heroPost.data.pubDate}
							slug={heroPost.id}
							tags={heroPost.data.tags}
							heroImage={heroPost.data.heroImage}
						/>
					</section>
				)}

				{featuredPosts.length > 0 && (
					<section class="featured-grid">
						{featuredPosts.map(post => (
							<ArticleCard
								title={post.data.title}
								description={post.data.description}
								pubDate={post.data.pubDate}
								slug={post.id}
								tags={post.data.tags}
								heroImage={post.data.heroImage}
								variant="vertical"
							/>
						))}
					</section>
				)}

				<div class="content-layout">
					<section class="article-feed">
						<h2 class="section-heading">Latest Articles</h2>
						{remainingPosts.map(post => (
							<ArticleCard
								title={post.data.title}
								description={post.data.description}
								pubDate={post.data.pubDate}
								slug={post.id}
								tags={post.data.tags}
								heroImage={post.data.heroImage}
								variant="horizontal"
							/>
						))}
					</section>

					<Sidebar />
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: 1.5rem 0;
	}
	.hero-section {
		margin-bottom: 1.5rem;
	}
	.featured-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.25rem;
		margin-bottom: 2rem;
	}
	.content-layout {
		display: grid;
		grid-template-columns: 1fr 340px;
		gap: 2.5rem;
		align-items: start;
	}
	.article-feed {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.section-heading {
		font-size: 1.1rem;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		color: var(--navy);
		margin: 0;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid var(--blue-light);
	}
	@media (max-width: 1024px) {
		.content-layout {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 768px) {
		.featured-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
