---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`All Articles — ${SITE_TITLE}`} description="Browse all Dallas Mavericks articles — trade rumors, game recaps, draft analysis, and community discussion from MavsBoard." />
	</head>
	<body>
		<Header />
		<main>
			<div class="container">
				<div class="page-header">
					<h1>All Articles</h1>
					<p>{posts.length} articles from the MavsBoard community</p>
				</div>
				<div class="content-layout">
					<section class="article-feed">
						{posts.map(post => (
							<ArticleCard
								title={post.data.title}
								description={post.data.description}
								pubDate={post.data.pubDate}
								slug={post.id}
								tags={post.data.tags}
								heroImage={post.data.heroImage}
								variant="horizontal"
							/>
						))}
					</section>
					<Sidebar />
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: 1.5rem 0;
	}
	.page-header {
		margin-bottom: 1.5rem;
	}
	.page-header h1 {
		margin-bottom: 0.25rem;
	}
	.page-header p {
		color: var(--text-muted);
		margin: 0;
	}
	.content-layout {
		display: grid;
		grid-template-columns: 1fr 340px;
		gap: 2rem;
		align-items: start;
	}
	.article-feed {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	@media (max-width: 1024px) {
		.content-layout {
			grid-template-columns: 1fr;
		}
	}
</style>
